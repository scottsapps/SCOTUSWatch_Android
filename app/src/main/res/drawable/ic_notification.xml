<?xml version="1.0" encoding="utf-8"?>
<!--
    Notification icon: scales of justice (balance scale)
    Must be white/transparent only — color is set by the system.
    24x24dp, optimized for status bar display.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Center post -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M12,2 L12,20" />
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:pathData="M12,2 L12,20" />

    <!-- Horizontal beam -->
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:pathData="M4,8 L20,8" />

    <!-- Left pan chain -->
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1"
        android:pathData="M6,8 L4,14" />
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1"
        android:pathData="M8,8 L4,14" />

    <!-- Right pan chain -->
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1"
        android:pathData="M16,8 L20,14" />
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1"
        android:pathData="M18,8 L20,14" />

    <!-- Left pan arc -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:pathData="M2,14 A2,1 0 0 0 6,14" />

    <!-- Right pan arc -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:pathData="M18,14 A2,1 0 0 0 22,14" />

    <!-- Base -->
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:pathData="M9,20 L15,20" />

</vector>
